default_platform(:mac)

# App Store Connect API-nøkkel (p8-filen hentes automatisk fra
# ~/.appstoreconnect/private_keys/AuthKey_9PJ79GJ677.p8)
API_KEY = app_store_connect_api_key(
  key_id:        "9PJ79GJ677",
  issuer_id:     "ec2486af-a2e0-466f-8d32-3c4acc72fac0",
  key_filepath:  File.expand_path("~/.appstoreconnect/private_keys/AuthKey_9PJ79GJ677.p8"),
  duration:      1200,
  in_house:      false
)

platform :mac do

  # -------------------------------------------------------
  # create_app — opprett app-oppføring i App Store Connect.
  # Kjøres én gang. Idempotent: feiler ikke hvis appen allerede finnes.
  # -------------------------------------------------------
  lane :create_app do
    produce(
      app_identifier: "GaiMS.OnePlayer",
      app_name:       "OnePlayer",
      platform:       "osx",
      language:       "English",
      skip_devcenter: false
    )
  end

  # -------------------------------------------------------
  # release — bygg, arkiver, last opp bygg + metadata + bilder
  # Bruk denne når du har en ny versjon klar til innsending.
  # -------------------------------------------------------
  lane :release do
    build_mac_app(
      scheme:           "OnePlayer",
      configuration:    "Release",
      export_method:    "app-store",
      output_directory: "./build",
      output_name:      "OnePlayer.pkg"
    )

    deliver(
      api_key:              API_KEY,
      pkg:                  "./build/OnePlayer.pkg",
      metadata_path:        "./fastlane/metadata",
      screenshots_path:     "./fastlane/screenshots",
      submit_for_review:    false,
      automatic_release:    false,
      force:                true,          # hopp over HTML-forhåndsvisning
      platform:             "osx",
      precheck_include_in_app_purchases: false
    )
  end

  # -------------------------------------------------------
  # metadata — last opp kun metadata og skjermbilder, ingen bygg.
  # Bruk denne for å oppdatere App Store-tekst og bilder uten ny versjon.
  # -------------------------------------------------------
  lane :metadata do
    deliver(
      api_key:              API_KEY,
      metadata_path:        "./fastlane/metadata",
      screenshots_path:     "./fastlane/screenshots",
      skip_binary_upload:   true,
      submit_for_review:    false,
      automatic_release:    false,
      force:                true,
      platform:             "osx",
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa:                   false,
        add_id_info_serves_ads:                  false,
        add_id_info_tracks_install:              false,
        add_id_info_tracks_action:               false,
        add_id_info_limits_tracking:             false,
        export_compliance_platform:              "ios",
        export_compliance_compliance_required:   false,
        export_compliance_encryption_updated:    false,
        export_compliance_app_type:              nil,
        export_compliance_uses_encryption:       false,
        export_compliance_is_exempt:             false,
        export_compliance_contains_third_party_cryptography: false,
        export_compliance_contains_proprietary_cryptography: false,
        export_compliance_available_on_french_store: false,
        content_rights_contains_third_party_content: false,
        content_rights_has_rights:               false
      }
    )
  end

end
